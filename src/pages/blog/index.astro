---
import { getCollection } from 'astro:content';
import Portfolio from '../../layouts/Portfolio.astro';

const allDocs = await getCollection('docs');

const posts = allDocs
  .filter(e => e.id.startsWith('blog/') && !e.id.match(/^blog\/index\.mdx?$/))
  .sort((a, b) => {
    const dateA = a.data.date ? new Date(a.data.date).getTime() : 0;
    const dateB = b.data.date ? new Date(b.data.date).getTime() : 0;
    return dateB - dateA;
  });

// Map project page titles to their URL so a post's `project` can link out.
const projectHref = new Map<string, string>();
allDocs
  .filter(e => e.id.startsWith('projects/') && !e.id.match(/^projects\/index\.mdx?$/))
  .forEach(p => projectHref.set(p.data.title, `/${p.id.replace(/\.mdx?$/, '')}/`));

const time = (d: Date | undefined) => (d ? new Date(d).getTime() : 0);

// Split posts into project groups and standalone posts.
const groups = new Map<string, typeof posts>();
const standalone: typeof posts = [];
for (const post of posts) {
  const project = post.data.project;
  if (project) {
    if (!groups.has(project)) groups.set(project, []);
    groups.get(project)!.push(post);
  } else {
    standalone.push(post);
  }
}

type Post = typeof posts[number];
type Block =
  | { kind: 'post'; date: number; post: Post }
  | { kind: 'project'; date: number; title: string; href: string | null; posts: Post[] };

const blocks: Block[] = [];
for (const post of standalone) {
  blocks.push({ kind: 'post', date: time(post.data.date), post });
}
for (const [title, list] of groups) {
  list.sort((a, b) => time(b.data.date) - time(a.data.date));
  blocks.push({
    kind: 'project',
    date: time(list[0].data.date),
    title,
    href: projectHref.get(title) ?? null,
    posts: list,
  });
}
// A project block is dated by its most recent post, so grouped and standalone
// entries stay interleaved newest-first.
blocks.sort((a, b) => b.date - a.date);

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
}
---
<Portfolio title="Blog | Luis Bretones">
  <style>
    .blog-header {
      padding: 4rem 0 2.5rem;
    }
    .blog-header h2 {
      font-family: 'Playfair Display', serif;
      font-size: 2.75rem;
      font-weight: 800;
      color: var(--text);
      margin-bottom: 0.5rem;
      line-height: 1.15;
    }
    .blog-header p {
      font-size: 0.95rem;
      color: var(--text-muted);
      max-width: 480px;
      line-height: 1.6;
    }

    .post-list {
      padding-bottom: 3rem;
    }

    .post-item {
      display: block;
      padding: 2rem 0 2rem 0;
      border-top: 1px solid var(--border);
      text-decoration: none;
      color: var(--text);
      transition: padding-left 0.2s ease;
    }
    .post-list > .post-item:last-child,
    .post-list > .project-group:last-child {
      border-bottom: 1px solid var(--border);
    }
    .post-item:hover {
      padding-left: 0.6rem;
    }

    /* Project grouping */
    .project-group {
      border-top: 1px solid var(--border);
      padding: 2rem 0 0.5rem;
    }
    .project-eyebrow {
      display: block;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.62rem;
      font-weight: 600;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 0.4rem;
    }
    .project-group-title {
      font-family: 'Playfair Display', serif;
      font-size: 1.7rem;
      font-weight: 800;
      color: var(--text);
      line-height: 1.2;
      text-decoration: none;
      transition: color 0.2s;
    }
    a.project-group-title:hover {
      color: var(--accent);
    }
    .group-posts {
      margin-top: 1rem;
      padding-left: 1.35rem;
      border-left: 2px solid color-mix(in srgb, var(--accent) 30%, transparent);
    }
    .group-posts .post-item {
      border-top: none;
      padding: 1.25rem 0;
    }
    .group-posts .post-item + .post-item {
      border-top: 1px solid var(--border);
    }

    .post-date {
      display: block;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.68rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 0.6rem;
    }

    .post-title {
      font-family: 'Playfair Display', serif;
      font-size: 1.4rem;
      font-weight: 700;
      color: var(--text);
      line-height: 1.3;
      margin-bottom: 0.6rem;
      transition: color 0.2s;
    }
    .post-item:hover .post-title {
      color: var(--accent);
    }

    .post-desc {
      font-size: 0.9rem;
      color: var(--text-muted);
      line-height: 1.65;
      margin-bottom: 0.85rem;
    }

    .post-tags {
      display: flex;
      gap: 0.35rem;
      flex-wrap: wrap;
    }
    .post-tag {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.62rem;
      font-weight: 500;
      padding: 0.15rem 0.5rem;
      border: 1px solid color-mix(in srgb, var(--accent) 35%, transparent);
      border-radius: 2px;
      color: var(--accent);
    }

    .post-read {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      margin-top: 1.1rem;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.04em;
      color: var(--accent);
    }
    .post-read .arrow {
      transition: transform 0.2s ease;
    }
    .post-item:hover .post-read .arrow {
      transform: translateX(5px);
    }

    .empty-state {
      padding: 3rem 0;
      font-size: 0.9rem;
      color: var(--text-muted);
      font-style: italic;
      border-top: 1px solid var(--border);
    }
  </style>

  <div class="blog-header">
    <h2>Blog</h2>
    <p>Personal log where I document progress, builds, and things I learn along the way.</p>
  </div>

  <div class="post-list">
    {blocks.length === 0 && (
      <p class="empty-state">No posts yet.</p>
    )}
    {blocks.map(block => {
      if (block.kind === 'post') {
        const post = block.post;
        const url = `/${post.id.replace(/\.mdx?$/, '')}/`;
        return (
          <a href={url} class="post-item">
            {post.data.date && (
              <time class="post-date" data-progress-url={post.data.progressUrl ?? undefined}>
                {post.data.progressUrl ? `Started ${formatDate(post.data.date)}` : formatDate(post.data.date)}
              </time>
            )}
            <p class="post-title">{post.data.title}</p>
            {post.data.description && (
              <p class="post-desc">{post.data.description}</p>
            )}
            {post.data.tags && post.data.tags.length > 0 && (
              <div class="post-tags">
                {post.data.tags.map(tag => (
                  <span class="post-tag">{tag}</span>
                ))}
              </div>
            )}
            <span class="post-read">Read post <span class="arrow">→</span></span>
          </a>
        );
      }

      return (
        <section class="project-group">
          <span class="project-eyebrow">Project</span>
          {block.href ? (
            <a class="project-group-title" href={block.href}>{block.title}</a>
          ) : (
            <span class="project-group-title">{block.title}</span>
          )}
          <div class="group-posts">
            {block.posts.map(post => {
              const url = `/${post.id.replace(/\.mdx?$/, '')}/`;
              return (
                <a href={url} class="post-item">
                  {post.data.date && (
                    <time class="post-date" data-progress-url={post.data.progressUrl ?? undefined}>
                      {post.data.progressUrl ? `Started ${formatDate(post.data.date)}` : formatDate(post.data.date)}
                    </time>
                  )}
                  <p class="post-title">{post.data.title}</p>
                  {post.data.description && (
                    <p class="post-desc">{post.data.description}</p>
                  )}
                  {post.data.tags && post.data.tags.length > 0 && (
                    <div class="post-tags">
                      {post.data.tags.map(tag => (
                        <span class="post-tag">{tag}</span>
                      ))}
                    </div>
                  )}
                  <span class="post-read">Read post <span class="arrow">→</span></span>
                </a>
              );
            })}
          </div>
        </section>
      );
    })}
  </div>

  <script>
    document.querySelectorAll('time[data-progress-url]').forEach(async (el) => {
      const url = el.getAttribute('data-progress-url');
      if (!url) return;
      try {
        const res = await fetch(url + '?t=' + Date.now());
        const data = await res.json();
        const log = Array.isArray(data.log) ? data.log : [];
        const last = log.length ? log[0].date : data.started;
        if (!last) return;
        const d = new Date(last + 'T00:00:00').toLocaleDateString('en-US', {
          year: 'numeric',
          month: 'short',
          day: 'numeric',
        });
        el.textContent = el.textContent + ' · Updated ' + d;
      } catch {}
    });
  </script>
</Portfolio>
