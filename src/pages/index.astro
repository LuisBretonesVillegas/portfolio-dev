---
import { getCollection } from 'astro:content';
import Portfolio from '../layouts/Portfolio.astro';

// Projects highlighted on the home page, in display order.
const FEATURED = [
  'projects/enterprise-network',
  'projects/java-summer-2026',
];

const allDocs = await getCollection('docs');
const featured = FEATURED
  .map(slug => allDocs.find(e => e.id.replace(/\.mdx?$/, '') === slug))
  .filter((e): e is NonNullable<typeof e> => Boolean(e));

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
}

// Latest blog post date for a project, so projects without a progress.json
// still get a "Started · Updated" label derived from their write-ups.
const blogPosts = allDocs.filter(e => e.id.startsWith('blog/') && !e.id.match(/^blog\/index\.mdx?$/));
function dateLabel(data: (typeof featured)[number]['data']): string {
  if (!data.date) return '';
  const started = formatDate(data.date);
  if (data.progressUrl) return `Started ${started}`;
  const times = blogPosts
    .filter(p => p.data.project === data.title && p.data.date)
    .map(p => new Date(p.data.date!).getTime());
  if (times.length) {
    const updated = new Date(Math.max(...times));
    if (updated.getTime() > new Date(data.date).getTime()) {
      return `Started ${started} · Updated ${formatDate(updated)}`;
    }
  }
  return started;
}
---
<Portfolio>
  <style>
    /* ── HERO ── */
    .hero {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 3rem;
      align-items: start;
      padding: 5rem 0 4rem;
      border-bottom: 1px solid var(--border);
    }
    .hero-meta {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.7rem;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 1.5rem;
    }
    h1 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(2.8rem, 6vw, 4rem);
      font-weight: 800;
      letter-spacing: -0.02em;
      line-height: 1.05;
      color: var(--text);
      margin-bottom: 0.75rem;
    }
    .role {
      font-size: 1rem;
      color: var(--text-muted);
      font-weight: 400;
      margin-bottom: 1.25rem;
    }
    .tagline {
      font-size: 0.975rem;
      color: var(--text-muted);
      line-height: 1.75;
      max-width: 460px;
      margin-bottom: 2rem;
    }
    .hero-actions { display: flex; gap: 0.75rem; flex-wrap: wrap; }
    .btn {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      padding: 0.55rem 1.1rem;
      border-radius: 3px;
      text-decoration: none;
      transition: background 0.15s, color 0.15s, border-color 0.15s;
    }
    .btn-primary {
      background: var(--accent);
      color: #fff;
      border: 1px solid var(--accent);
    }
    .btn-primary:hover { background: #0f3a00; border-color: #0f3a00; }
    .btn-secondary {
      background: transparent;
      color: var(--accent);
      border: 1px solid var(--accent);
    }
    .btn-secondary:hover { background: color-mix(in srgb, var(--accent) 10%, transparent); }
    .hero-right { padding-top: 5rem; display: flex; justify-content: center; }
    .avatar {
      width: 280px;
      height: 280px;
      border-radius: 50%;
      object-fit: cover;
      object-position: center top;
      border: 2px solid var(--border);
    }

    /* ── SKILLS GRID ── */
    .skill-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      border: 1px solid #b8b3ab;
      border-radius: 4px;
      overflow: hidden;
      background: #b8b3ab;
    }
    .skill-cell {
      padding: 1.25rem 1.1rem;
      background: #eae6de;
      border-right: 1px solid #b8b3ab;
      border-bottom: 1px solid #b8b3ab;
    }
    .skill-cell:nth-child(3n) { border-right: none; }
    .skill-cell:nth-last-child(-n+3) { border-bottom: none; }
    .skill-cell-title {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.6rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      margin-bottom: 0.85rem;
    }
    .skill-cell-tags { display: flex; flex-wrap: wrap; gap: 0.35rem; }
    .skill-tag {
      font-size: 0.78rem;
      padding: 0.2rem 0.55rem;
      border-radius: 2px;
      background: var(--bg);
      cursor: default;
    }
    .c-green .skill-cell-title { color: var(--accent); }
    .c-green .skill-tag { border: 1px solid color-mix(in srgb, var(--accent) 40%, transparent); color: var(--accent); }

    .c-blue .skill-cell-title { color: #3d7fc1; }
    .c-blue .skill-tag { border: 1px solid #a3c4e8; color: #3d7fc1; }
    .c-orange .skill-cell-title { color: #b85c2a; }
    .c-orange .skill-tag { border: 1px solid #dda882; color: #b85c2a; }
    .c-purple .skill-cell-title { color: #6b5fa0; }
    .c-purple .skill-tag { border: 1px solid #b8aed6; color: #6b5fa0; }
    .c-teal .skill-cell-title { color: #2e8c76; }
    .c-teal .skill-tag { border: 1px solid #8fcfc0; color: #2e8c76; }
    .c-muted .skill-cell-title { color: var(--text-muted); }
    .c-muted .skill-tag { border: 1px solid var(--border); color: var(--text-muted); }

    /* ── FEATURED PROJECTS ── */
    .featured-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 0.85rem;
    }
    .featured-card {
      display: flex;
      flex-direction: column;
      gap: 0.6rem;
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 1.4rem 1.3rem 1.2rem;
      text-decoration: none;
      color: var(--text);
      transition: border-color 0.15s;
    }
    .featured-card:hover { border-color: var(--accent); }
    .featured-date {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.62rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--accent);
    }
    .featured-title {
      font-family: 'Playfair Display', serif;
      font-size: 1.35rem;
      font-weight: 700;
      line-height: 1.25;
      color: var(--text);
      transition: color 0.2s;
    }
    .featured-card:hover .featured-title { color: var(--accent); }
    .featured-desc {
      font-size: 0.875rem;
      color: var(--text-muted);
      line-height: 1.6;
      flex: 1;
    }
    .featured-tags {
      display: flex;
      gap: 0.35rem;
      flex-wrap: wrap;
    }
    .featured-tag {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.62rem;
      font-weight: 500;
      padding: 0.15rem 0.5rem;
      border: 1px solid color-mix(in srgb, var(--accent) 35%, transparent);
      border-radius: 2px;
      color: var(--accent);
    }
    .featured-read {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      margin-top: 0.4rem;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.04em;
      color: var(--accent);
    }
    .featured-read .arrow {
      transition: transform 0.2s ease;
    }
    .featured-card:hover .featured-read .arrow {
      transform: translateX(5px);
    }

    /* ── CERT GRID ── */
    .cert-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 0.85rem;
    }
    .cert-card {
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 1.1rem 1rem 0.9rem;
      display: flex;
      flex-direction: column;
      gap: 0.6rem;
      position: relative;
      overflow: hidden;
    }
    .cert-card.active { border-color: var(--accent); }
    .cert-card.active::before {
      content: '';
      position: absolute;
      inset: 0 0 auto 0;
      height: 3px;
      background: var(--accent);
    }
    .cert-vendor {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.58rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--text-muted);
    }
    .cert-acronym {
      font-family: 'Playfair Display', serif;
      font-size: 2rem;
      font-weight: 800;
      line-height: 1;
      color: var(--text);
    }
    .cert-card.active .cert-acronym { color: var(--accent); }
    .cert-fullname {
      font-size: 0.72rem;
      color: var(--text-muted);
      line-height: 1.4;
      flex: 1;
    }
    .cert-status {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.58rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      align-self: flex-start;
      padding: 0.2rem 0.5rem;
      border-radius: 3px;
    }
    .cert-status.status-active {
      background: color-mix(in srgb, var(--accent) 12%, transparent);
      color: var(--accent);
      border: 1px solid color-mix(in srgb, var(--accent) 35%, transparent);
    }
    .cert-status.status-planned {
      background: transparent;
      color: var(--text-muted);
      border: 1px solid var(--border);
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 768px) {
      .hero {
        grid-template-columns: 1fr;
        gap: 1.5rem;
        padding: 2.5rem 0 2rem;
        text-align: left;
      }
      .hero-right {
        order: -1;
        display: flex;
        justify-content: flex-start;
        padding-top: 0;
      }
      .avatar { width: 88px; height: 88px; }
      .tagline { max-width: 100%; }
      h1 { font-size: clamp(2.2rem, 10vw, 3rem); }
      .skill-grid { grid-template-columns: repeat(2, 1fr); }
      .skill-cell:nth-child(3n) { border-right: 1px solid #b8b3ab; }
      .skill-cell:nth-child(2n) { border-right: none; }
      .cert-grid { grid-template-columns: repeat(2, 1fr); }
      .featured-grid { grid-template-columns: 1fr; }
    }
  </style>

  <section class="hero">
    <div class="hero-left">
      <h1>Luis Bretones</h1>
      <p class="role">Computer Engineering Student</p>
      <p class="tagline">
        Networking &amp; cloud infrastructure.<br />
        Building toward CCNA and AWS certifications.<br />
        Documenting what I learn and build along the way.
      </p>
      <div class="hero-actions">
        <a href="/projects/" class="btn btn-primary">Projects →</a>
        <a href="/blog/" class="btn btn-secondary">Blog →</a>
      </div>
    </div>
    <div class="hero-right">
      <img src="/avatar.jpeg" alt="Luis Bretones" class="avatar" />
    </div>
  </section>

  <section class="section" id="skills" style="scroll-margin-top: 80px;">
    <p class="section-title">Skills // Current stack</p>
    <div class="skill-grid">
      <div class="skill-cell c-green">
        <p class="skill-cell-title">Networking</p>
        <div class="skill-cell-tags">
          <span class="skill-tag">TCP/IP</span>
          <span class="skill-tag">Routing & Switching</span>
          <span class="skill-tag">VLANs</span>
          <span class="skill-tag">Subnetting</span>
          <span class="skill-tag">BGP</span>
          <span class="skill-tag">OSPF</span>
          <span class="skill-tag">Cisco IOS</span>
        </div>
      </div>
      <div class="skill-cell c-blue">
        <p class="skill-cell-title">Cloud & Infra</p>
        <div class="skill-cell-tags">
          <span class="skill-tag">AWS</span>
          <span class="skill-tag">Docker</span>
          <span class="skill-tag">Linux</span>
          <span class="skill-tag">Bash</span>
          <span class="skill-tag">GitHub Actions</span>
        </div>
      </div>
      <div class="skill-cell c-orange">
        <p class="skill-cell-title">Analysis & Tools</p>
        <div class="skill-cell-tags">
          <span class="skill-tag">Wireshark</span>
          <span class="skill-tag">Packet Tracer</span>
          <span class="skill-tag">GNS3</span>
          <span class="skill-tag">Nmap</span>
          <span class="skill-tag">tcpdump</span>
        </div>
      </div>
      <div class="skill-cell c-purple">
        <p class="skill-cell-title">Programming</p>
        <div class="skill-cell-tags">
          <span class="skill-tag">Java</span>
          <span class="skill-tag">Python</span>
          <span class="skill-tag">C</span>
          <span class="skill-tag">Bash</span>
          <span class="skill-tag">Git</span>
        </div>
      </div>
      <div class="skill-cell c-teal">
        <p class="skill-cell-title">OS & Systems</p>
        <div class="skill-cell-tags">
          <span class="skill-tag">Arch Linux</span>
          <span class="skill-tag">Debian 13</span>
          <span class="skill-tag">Windows Server</span>
          <span class="skill-tag">VirtualBox</span>
        </div>
      </div>
      <div class="skill-cell c-muted">
        <p class="skill-cell-title">Project Management</p>
        <div class="skill-cell-tags">
          <span class="skill-tag">Git Flow</span>
          <span class="skill-tag">GitHub</span>
          <span class="skill-tag">Markdown</span>
          <span class="skill-tag">Documentation</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <p class="section-title">Featured // Selected projects</p>
    <div class="featured-grid">
      {featured.map(project => {
        const url = `/${project.id.replace(/\.mdx?$/, '')}/`;
        return (
          <a href={url} class="featured-card">
            {project.data.date && (
              <time class="featured-date" data-progress-url={project.data.progressUrl ?? undefined}>
                {dateLabel(project.data)}
              </time>
            )}
            <p class="featured-title">{project.data.title}</p>
            {project.data.description && (
              <p class="featured-desc">{project.data.description}</p>
            )}
            {project.data.tags && project.data.tags.length > 0 && (
              <div class="featured-tags">
                {project.data.tags.map(tag => (
                  <span class="featured-tag">{tag}</span>
                ))}
              </div>
            )}
            <span class="featured-read">View project <span class="arrow">→</span></span>
          </a>
        );
      })}
    </div>
  </section>

  <section class="section">
    <p class="section-title">Certifications // Roadmap</p>
    <div class="cert-grid">
      <div class="cert-card active">
        <span class="cert-vendor">Cisco</span>
        <span class="cert-acronym">CCNA</span>
        <span class="cert-fullname">Cisco Certified Network Associate</span>
        <span class="cert-status status-active">In progress</span>
      </div>
      <div class="cert-card active">
        <span class="cert-vendor">AWS</span>
        <span class="cert-acronym">CCP</span>
        <span class="cert-fullname">AWS Certified Cloud Practitioner</span>
        <span class="cert-status status-active">In progress</span>
      </div>
      <div class="cert-card">
        <span class="cert-vendor">Cisco</span>
        <span class="cert-acronym">CCNP</span>
        <span class="cert-fullname">Cisco Certified Network Professional</span>
        <span class="cert-status status-planned">Planned</span>
      </div>
      <div class="cert-card">
        <span class="cert-vendor">AWS</span>
        <span class="cert-acronym">SAA</span>
        <span class="cert-fullname">AWS Solutions Architect Associate</span>
        <span class="cert-status status-planned">Planned</span>
      </div>
    </div>
  </section>

  <script>
    document.querySelectorAll('time[data-progress-url]').forEach(async (el) => {
      const url = el.getAttribute('data-progress-url');
      if (!url) return;
      try {
        const res = await fetch(url + '?t=' + Date.now());
        const data = await res.json();
        const log = Array.isArray(data.log) ? data.log : [];
        const last = log.length ? log[0].date : data.started;
        if (!last) return;
        const d = new Date(last + 'T00:00:00').toLocaleDateString('en-US', {
          year: 'numeric',
          month: 'short',
          day: 'numeric',
        });
        el.textContent = el.textContent + ' · Updated ' + d;
      } catch {}
    });
  </script>
</Portfolio>
