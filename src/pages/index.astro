---
import Portfolio from '../layouts/Portfolio.astro';
---
<Portfolio>
  <style>
    /* ── HERO ── */
    .hero {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 3rem;
      align-items: start;
      padding: 5rem 0 4rem;
      border-bottom: 1px solid var(--border);
    }
    .hero-meta {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.7rem;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 1.5rem;
    }
    h1 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(2.8rem, 6vw, 4rem);
      font-weight: 800;
      letter-spacing: -0.02em;
      line-height: 1.05;
      color: var(--text);
      margin-bottom: 0.75rem;
    }
    .role {
      font-size: 1rem;
      color: var(--text-muted);
      font-weight: 400;
      margin-bottom: 1.25rem;
    }
    .tagline {
      font-size: 0.975rem;
      color: var(--text-muted);
      line-height: 1.75;
      max-width: 460px;
      margin-bottom: 2rem;
    }
    .hero-keywords {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.7rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--text-muted);
      line-height: 1.9;
    }
    .hero-right { padding-top: 5rem; display: flex; justify-content: center; }
    .avatar {
      width: 280px;
      height: 280px;
      border-radius: 50%;
      object-fit: cover;
      object-position: center top;
      border: 2px solid var(--border);
    }

    /* ── SKILLS GRID ── */
    .skill-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      border: 1px solid var(--border);
      border-radius: 4px;
      overflow: hidden;
    }
    .skill-cell {
      padding: 1.25rem 1.1rem;
      border-right: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
    }
    .skill-cell:nth-child(3n) { border-right: none; }
    .skill-cell:nth-last-child(-n+3) { border-bottom: none; }
    .skill-cell-title {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.6rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      margin-bottom: 0.85rem;
    }
    .skill-cell-tags { display: flex; flex-wrap: wrap; gap: 0.35rem; }
    .skill-tag {
      font-size: 0.78rem;
      padding: 0.2rem 0.55rem;
      border-radius: 4px;
      background: var(--bg);
      cursor: default;
    }
    .c-green .skill-cell-title { color: var(--accent); }
    .c-green .skill-tag { border: 1px solid color-mix(in srgb, var(--accent) 40%, transparent); color: var(--accent); }
    .c-blue .skill-cell-title { color: #3d7fc1; }
    .c-blue .skill-tag { border: 1px solid #a3c4e8; color: #3d7fc1; }
    .c-orange .skill-cell-title { color: #b85c2a; }
    .c-orange .skill-tag { border: 1px solid #dda882; color: #b85c2a; }
    .c-purple .skill-cell-title { color: #6b5fa0; }
    .c-purple .skill-tag { border: 1px solid #b8aed6; color: #6b5fa0; }
    .c-teal .skill-cell-title { color: #2e8c76; }
    .c-teal .skill-tag { border: 1px solid #8fcfc0; color: #2e8c76; }
    .c-muted .skill-cell-title { color: var(--text-muted); }
    .c-muted .skill-tag { border: 1px solid var(--border); color: var(--text-muted); }

    /* ── CERT GRID ── */
    .cert-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 0.85rem;
    }
    .cert-card {
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 1.1rem 1rem 0.9rem;
      display: flex;
      flex-direction: column;
      gap: 0.6rem;
      position: relative;
      overflow: hidden;
    }
    .cert-card.active { border-color: var(--accent); }
    .cert-card.active::before {
      content: '';
      position: absolute;
      inset: 0 0 auto 0;
      height: 3px;
      background: var(--accent);
    }
    .cert-vendor {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.58rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--text-muted);
    }
    .cert-acronym {
      font-family: 'Playfair Display', serif;
      font-size: 2rem;
      font-weight: 800;
      line-height: 1;
      color: var(--text);
    }
    .cert-card.active .cert-acronym { color: var(--accent); }
    .cert-fullname {
      font-size: 0.72rem;
      color: var(--text-muted);
      line-height: 1.4;
      flex: 1;
    }
    .cert-status {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.58rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      align-self: flex-start;
      padding: 0.2rem 0.5rem;
      border-radius: 3px;
    }
    .cert-status.status-active {
      background: color-mix(in srgb, var(--accent) 12%, transparent);
      color: var(--accent);
      border: 1px solid color-mix(in srgb, var(--accent) 35%, transparent);
    }
    .cert-status.status-planned {
      background: transparent;
      color: var(--text-muted);
      border: 1px solid var(--border);
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 768px) {
      .hero { grid-template-columns: 1fr auto; gap: 1.25rem; align-items: start; }
      .hero-right { display: flex; padding-top: 3.5rem; }
      .avatar { width: 110px; height: 110px; }
      .skill-grid { grid-template-columns: repeat(2, 1fr); }
      .skill-cell:nth-child(3n) { border-right: 1px solid var(--border); }
      .skill-cell:nth-child(2n) { border-right: none; }
      .cert-grid { grid-template-columns: repeat(2, 1fr); }
    }
  </style>

  <section class="hero">
    <div class="hero-left">
      <p class="hero-meta">Luis Bretones // Networking // Almería</p>
      <h1>Luis Bretones</h1>
      <p class="role">Computer Engineering Student</p>
      <p class="tagline">
        Networking &amp; cloud infrastructure.<br />
        Building toward CCNA and AWS certifications.<br />
        Documenting what I learn and build along the way.
      </p>
      <p class="hero-keywords">
        Networking // Cloud Infrastructure //<br />
        Linux // Wireshark // Docker
      </p>
    </div>
    <div class="hero-right">
      <img src="/avatar.jpeg" alt="Luis Bretones" class="avatar" />
    </div>
  </section>

  <section class="section" id="skills">
    <p class="section-title">Skills // Current stack</p>
    <div class="skill-grid">
      <div class="skill-cell c-green">
        <p class="skill-cell-title">Networking</p>
        <div class="skill-cell-tags">
          <span class="skill-tag">TCP/IP</span>
          <span class="skill-tag">Routing & Switching</span>
          <span class="skill-tag">VLANs</span>
          <span class="skill-tag">Subnetting</span>
          <span class="skill-tag">BGP</span>
          <span class="skill-tag">OSPF</span>
          <span class="skill-tag">Cisco IOS</span>
        </div>
      </div>
      <div class="skill-cell c-blue">
        <p class="skill-cell-title">Cloud & Infra</p>
        <div class="skill-cell-tags">
          <span class="skill-tag">AWS</span>
          <span class="skill-tag">Docker</span>
          <span class="skill-tag">Linux</span>
          <span class="skill-tag">Bash</span>
          <span class="skill-tag">GitHub Actions</span>
        </div>
      </div>
      <div class="skill-cell c-orange">
        <p class="skill-cell-title">Analysis & Tools</p>
        <div class="skill-cell-tags">
          <span class="skill-tag">Wireshark</span>
          <span class="skill-tag">Packet Tracer</span>
          <span class="skill-tag">GNS3</span>
          <span class="skill-tag">Nmap</span>
          <span class="skill-tag">tcpdump</span>
        </div>
      </div>
      <div class="skill-cell c-purple">
        <p class="skill-cell-title">Programming</p>
        <div class="skill-cell-tags">
          <span class="skill-tag">Java</span>
          <span class="skill-tag">Python</span>
          <span class="skill-tag">C</span>
          <span class="skill-tag">Bash</span>
          <span class="skill-tag">Git</span>
        </div>
      </div>
      <div class="skill-cell c-teal">
        <p class="skill-cell-title">OS & Systems</p>
        <div class="skill-cell-tags">
          <span class="skill-tag">Arch Linux</span>
          <span class="skill-tag">Ubuntu</span>
          <span class="skill-tag">Windows Server</span>
          <span class="skill-tag">VirtualBox</span>
        </div>
      </div>
      <div class="skill-cell c-muted">
        <p class="skill-cell-title">Project Management</p>
        <div class="skill-cell-tags">
          <span class="skill-tag">Git Flow</span>
          <span class="skill-tag">GitHub</span>
          <span class="skill-tag">Markdown</span>
          <span class="skill-tag">Documentation</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <p class="section-title">Repository feed // Featured</p>
    <div class="repo-feed">
      <a href="/projects/protocol-analysis-wireless-audio-transceivers/" class="repo-item">
        <div class="repo-item-header">
          <span class="repo-item-name">protocol-analysis-wireless-audio-transceivers</span>
          <span class="repo-item-src">view_source →</span>
        </div>
        <div class="repo-item-tags">
          <span class="repo-item-tag">USB</span>
          <span class="repo-item-tag">networking</span>
          <span class="repo-item-tag">arch-linux</span>
          <span class="repo-item-tag">wireshark</span>
        </div>
        <p class="repo-item-desc">Low-level USB protocol analysis of a Corsair wireless audio dongle: descriptor enumeration, interface mapping, and traffic capture on Arch Linux.</p>
      </a>
    </div>
    <a href="/projects/" class="view-all">~/explore_all →</a>
  </section>

  <section class="section">
    <p class="section-title">Certifications // Roadmap</p>
    <div class="cert-grid">
      <div class="cert-card active">
        <span class="cert-vendor">Cisco</span>
        <span class="cert-acronym">CCNA</span>
        <span class="cert-fullname">Cisco Certified Network Associate</span>
        <span class="cert-status status-active">In progress</span>
      </div>
      <div class="cert-card active">
        <span class="cert-vendor">AWS</span>
        <span class="cert-acronym">CCP</span>
        <span class="cert-fullname">AWS Certified Cloud Practitioner</span>
        <span class="cert-status status-active">In progress</span>
      </div>
      <div class="cert-card">
        <span class="cert-vendor">Cisco</span>
        <span class="cert-acronym">CCNP</span>
        <span class="cert-fullname">Cisco Certified Network Professional</span>
        <span class="cert-status status-planned">Planned</span>
      </div>
      <div class="cert-card">
        <span class="cert-vendor">AWS</span>
        <span class="cert-acronym">SAA</span>
        <span class="cert-fullname">AWS Solutions Architect Associate</span>
        <span class="cert-status status-planned">Planned</span>
      </div>
    </div>
  </section>
</Portfolio>
