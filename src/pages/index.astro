<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Luis Bretones — Computer Engineering Student</title>
  <meta name="description" content="Computer Engineering student at UAL, focused on networking and cloud infrastructure." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #eef2f7;
      --bg-card: #ffffff;
      --text: #0f172a;
      --text-muted: #64748b;
      --accent: #1d4ed8;
      --accent-light: #3b82f6;
      --border: #e2e8f0;
      --dot: #bfdbfe;
      --shadow: rgba(29, 78, 216, 0.08);
    }
    [data-theme="dark"] {
      --bg: #0f172a;
      --bg-card: #1e293b;
      --text: #f1f5f9;
      --text-muted: #94a3b8;
      --accent: #3b82f6;
      --accent-light: #60a5fa;
      --border: #1e3a8a;
      --dot: #1e3a8a;
      --shadow: rgba(59, 130, 246, 0.08);
    }

    body {
      font-family: 'Inter', sans-serif;
      background-color: var(--bg);
      background-image: radial-gradient(circle, var(--dot) 1.5px, transparent 1.5px);
      background-size: 28px 28px;
      color: var(--text);
      min-height: 100vh;
      transition: background-color 0.3s, color 0.3s;
    }

    /* ── NAV ── */
    nav {
      position: fixed;
      inset: 0 0 auto 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1rem 2.5rem;
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      background: rgba(238, 242, 247, 0.75);
      border-bottom: 1px solid var(--border);
      transition: background 0.3s;
    }
    [data-theme="dark"] nav { background: rgba(15, 23, 42, 0.75); }

    .logo {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.95rem;
      font-weight: 500;
      color: var(--accent);
      text-decoration: none;
      letter-spacing: -0.02em;
    }
    .nav-right {
      display: flex;
      align-items: center;
      gap: 1.75rem;
    }
    .nav-link {
      font-size: 0.875rem;
      font-weight: 500;
      color: var(--text-muted);
      text-decoration: none;
      transition: color 0.2s;
    }
    .nav-link:hover { color: var(--accent); }
    .nav-icon-link {
      color: var(--text-muted);
      display: flex;
      align-items: center;
      transition: color 0.2s;
    }
    .nav-icon-link:hover { color: var(--accent); }
    .theme-btn {
      background: none;
      border: 1px solid var(--border);
      border-radius: 50%;
      width: 34px;
      height: 34px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--text-muted);
      transition: border-color 0.2s, color 0.2s;
    }
    .theme-btn:hover { border-color: var(--accent); color: var(--accent); }
    #sun-icon { display: none; }
    [data-theme="dark"] #moon-icon { display: none; }
    [data-theme="dark"] #sun-icon { display: block; }

    /* ── HERO ── */
    .hero {
      min-height: calc(100vh - 57px);
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 2rem;
    }
    .hero-inner {
      display: flex;
      align-items: center;
      gap: 3.5rem;
      max-width: 820px;
      width: 100%;
    }
    .avatar {
      width: 170px;
      height: 170px;
      border-radius: 50%;
      object-fit: cover;
      object-position: center top;
      border: 3px solid var(--accent);
      box-shadow: 0 0 0 8px rgba(29, 78, 216, 0.1), 0 20px 40px var(--shadow);
      flex-shrink: 0;
    }
    .hi {
      display: block;
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 0.6rem;
    }
    h1 {
      font-size: clamp(2.5rem, 5vw, 3.75rem);
      font-weight: 800;
      letter-spacing: -0.03em;
      line-height: 1.05;
      color: var(--text);
      margin-bottom: 0.3rem;
    }
    .role {
      font-size: 0.95rem;
      color: var(--text-muted);
      margin-bottom: 1.1rem;
    }
    .tagline {
      font-size: 0.975rem;
      color: var(--text-muted);
      line-height: 1.7;
      max-width: 400px;
      margin-bottom: 1.75rem;
    }
    .actions {
      display: flex;
      align-items: center;
      gap: 1.1rem;
      flex-wrap: wrap;
    }
    .icon-btn {
      color: var(--text-muted);
      display: flex;
      align-items: center;
      transition: color 0.2s;
    }
    .icon-btn:hover { color: var(--accent); }
    .cta {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.825rem;
      font-weight: 500;
      padding: 0.55rem 1.1rem;
      border: 1.5px solid var(--accent);
      color: var(--accent);
      text-decoration: none;
      border-radius: 4px;
      transition: background 0.2s, color 0.2s;
    }
    .cta:hover { background: var(--accent); color: #fff; }

    main { padding-top: 57px; }

    /* ── TICKER ── */
    .ticker-wrap {
      overflow: hidden;
      padding: 0.6rem 0;
    }
    .ticker {
      display: flex;
      width: max-content;
      animation: scroll 35s linear infinite;
    }
    .ticker-text {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.8rem;
      font-weight: 500;
      white-space: nowrap;
      padding-right: 2rem;
      color: var(--accent);
    }
    @keyframes scroll {
      from { transform: translateX(0); }
      to   { transform: translateX(-50%); }
    }

    /* ── PROJECTS ── */
    .projects {
      max-width: 940px;
      margin: 5rem auto;
      padding: 0 2rem;
    }
    .section-header {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      font-size: 1.1rem;
      font-weight: 700;
      margin-bottom: 1.75rem;
      padding-bottom: 0.75rem;
      border-bottom: 1px solid var(--border);
    }
    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
      gap: 1.25rem;
    }
    .card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 1.5rem;
      text-decoration: none;
      color: var(--text);
      display: block;
      transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
    }
    .card:hover {
      border-color: var(--accent);
      transform: translateY(-3px);
      box-shadow: 0 8px 24px var(--shadow);
    }
    .card h3 {
      font-size: 0.975rem;
      font-weight: 600;
      margin-bottom: 0.5rem;
    }
    .card p {
      font-size: 0.85rem;
      color: var(--text-muted);
      line-height: 1.65;
      margin-bottom: 1.1rem;
    }
    .tags { display: flex; gap: 0.5rem; flex-wrap: wrap; }
    .tag {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.65rem;
      font-weight: 700;
      letter-spacing: 0.06em;
      padding: 0.2rem 0.55rem;
      border-radius: 3px;
      color: #fff;
    }
    .tag-blue   { background: #1d4ed8; }
    .tag-green  { background: #059669; }
    .tag-orange { background: #d97706; }
    .tag-purple { background: #7c3aed; }

    .view-all {
      display: inline-block;
      margin-top: 1.25rem;
      font-size: 0.875rem;
      font-weight: 500;
      color: var(--accent);
      text-decoration: none;
    }
    .view-all:hover { text-decoration: underline; }

    /* ── RESPONSIVE ── */
    @media (max-width: 600px) {
      .hero-inner { flex-direction: column; text-align: center; gap: 1.75rem; }
      .tagline { margin-inline: auto; }
      .actions { justify-content: center; }
      .grid { grid-template-columns: 1fr; }
      nav { padding: 0.875rem 1.25rem; }
    }
  </style>
</head>
<body>

  <nav>
