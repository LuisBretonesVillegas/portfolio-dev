---
<div class="sl-site-title">
  <a href="/" class="sl-back-link" aria-label="Back to portfolio">
    <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
      <polyline points="15 18 9 12 15 6"/>
    </svg>
    Portfolio
  </a>
  <a href="/projects/" class="sl-title-logo">
    <img src="/favicon.svg" alt="LB" width="26" height="26" />
    <span>DOCS</span>
  </a>
</div>

<style>
  .sl-site-title {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-family: 'Inter', sans-serif;
    height: 100%;
  }
  .sl-back-link {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--sl-color-gray-3);
    text-decoration: none;
    transition: color 0.2s;
    white-space: nowrap;
    line-height: 1;
  }
  .sl-back-link:hover { color: var(--sl-color-accent); }
  .sl-title-logo {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    text-decoration: none;
    font-family: 'Inter', sans-serif;
    line-height: 1;
  }
  .sl-title-logo span {
    color: var(--sl-color-white);
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.05em;
  }
</style>
